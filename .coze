[project]
requires = ["nodejs-24"]

[dev]
build = ["bash", "-c", "cd backend && pnpm install && cd ../frontend && pnpm install && pnpm run build && cd ../backend && pnpm run build"]
run = ["/usr/bin/node", "backend/dist/index.js"]

[deploy]
build = ["bash", "-c", "cd backend && pnpm install && cd ../frontend && pnpm install && pnpm run build && cd ../backend && pnpm run build"]
run = ["/usr/bin/node", "backend/dist/index.js"]
