# AI 红娘 Backend 环境变量配置

# 服务器配置
PORT=4000

# OpenAI API 配置（可选，用于更智能的消息生成）
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-4

# 数据库配置（开发环境使用 SQLite，生产环境使用 MySQL）
DATABASE_URL=sqlite://./data/ai-dating.db

# JWT 密钥（生产环境请使用强密钥）
JWT_SECRET=your-secret-key-change-in-production

# 日志级别
LOG_LEVEL=info
